# Which LLM backend to use: "gemini" (has a free tier) or "anthropic" (paid, higher quality)
LLM_PROVIDER=gemini

# Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Anthropic API key — only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here
